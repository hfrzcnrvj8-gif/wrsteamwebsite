# Canonical site URL — used by sitemap.xml, robots.txt and canonical/OG tags.
# Set this to your real domain on the host (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://poltechnickx.com

# Booking link for the "book a call" CTAs (optional).
# Set to your Calendly / Cal.com URL; falls back to the contact form.
# NEXT_PUBLIC_BOOKING_URL=https://cal.com/poltechnickx/intro

# Contact form email delivery (optional).
# Without these, submissions are validated and logged to the server console,
# and the form still returns success — so it works out of the box in dev.
#
# To actually deliver email, create a Resend API key (https://resend.com)
# and set the following, then restart the server:

# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# CONTACT_TO_EMAIL=hello@poltechnickx.com
# CONTACT_FROM_EMAIL=poltechnickx <onboarding@resend.dev>
