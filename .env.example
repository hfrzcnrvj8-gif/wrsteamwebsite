# Canonical site URL — used by sitemap.xml, robots.txt and canonical/OG tags.
# Set this on the host (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://www.reifenservice-hannover.com

# Booking link for the "Termin vereinbaren" CTAs (optional).
# Defaults to click-to-call (tel:+4951384520) — see lib/site.ts.
# NEXT_PUBLIC_BOOKING_URL=https://cal.com/wollny/termin

# Google Maps / reviews overrides (optional; sensible fallbacks in lib/site.ts).
# NEXT_PUBLIC_MAPS_EMBED_URL=
# NEXT_PUBLIC_GOOGLE_REVIEWS_URL=

# Contact form email delivery.
# Without these, submissions are validated and logged to the server console and
# the form still returns success — fine for dev, NOT for production.
# Create a Resend API key (https://resend.com), verify the sending domain, then:
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# CONTACT_TO_EMAIL=info@reifenservice-hannover.com
# CONTACT_FROM_EMAIL=Wollny Reifenservice <kontakt@reifenservice-hannover.com>
